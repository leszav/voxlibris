{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev:client": "vite dev --port 3000",
    "dev:server": "NODE_ENV=development tsx --import ./server/env.ts server/index.ts",
    "dev:services": "docker compose up postgres minio -d",
    "kill-ports": "tsx script/force-kill-ports.ts",
    "init-storage": "tsx script/init-storage.ts",
    "dev": "pnpm run kill-ports && pnpm run dev:services && pnpm run init-storage && (pnpm run dev:server & pnpm run dev:client)",
    "dev:both": "concurrently \"pnpm run dev:server\" \"pnpm run dev:client\" --names \"backend,frontend\" --prefix-colors \"blue,green\"",
    "dev:stop": "docker compose down",
    "build": "tsx script/build.ts",
    "start": "NODE_ENV=production node --import ./dist/server/env.js dist/server/index.js",
    "check": "tsc",
    "quality:gate": "pnpm run check && pnpm run lint:eslint && pnpm run build",
    "test": "node --test --experimental-strip-types server/__tests__/**/*.test.ts",
    "test:watch": "node --test --watch server/__tests__/**/*.test.ts",
    "test:coverage": "node --test --experimental-test-coverage server/__tests__/**/*.test.ts",
    "test:integration": "node --test --test-concurrency=1 --experimental-strip-types server/__tests__/integration/**/*.integration.test.ts",
    "stage12:reader-clubs": "tsx script/stage12-reader-clubs-smoke.ts",
    "deps:cruise": "depcruise --config .dependency-cruiser.cjs \"client/src/**/*.{ts,tsx}\" \"server/**/*.ts\" \"shared/**/*.ts\"",
    "deps:graph": "depcruise --config .dependency-cruiser.cjs --output-type json --output-to /tmp/voxlibris-dependency-cruiser.json \"client/src/**/*.{ts,tsx}\" \"server/**/*.ts\" \"shared/**/*.ts\" && node --import tsx script/render-dependency-visualizations.ts /tmp/voxlibris-dependency-cruiser.json",
    "lint": "tsc --noEmit",
    "lint:eslint": "eslint . --ext .ts,.tsx",
    "lint:eslint:fix": "eslint . --ext .ts,.tsx --fix",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "images:check:static": "tsx script/check-static-images.ts",
    "images:optimize:static": "tsx script/optimize-static-images.ts",
    "seed": "tsx script/seed.ts",
    "prepare": "husky"
  },
