    "eslint": "^9.39.2",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.20.5",
    "typescript": "5.9.3",
    "vite": "^7.3.0"
  },
  "optionalDependencies": {
    "bufferutil": "^4.1.0"
  },
  "pnpm": {
    "overrides": {
      "jws": "4.0.1",
      "esbuild@<=0.24.2": ">=0.25.0",
