# xLibris Package Registry Configuration
# Приоритет реестров: локальный Verdaccio -> npmmirror -> npmjs

#registry=http://192.168.1.8:4873
registry=https://registry.npmjs.org/

# Fallback registries
@*:registry=https://registry.npmmirror.com/

# Security settings
audit-level=moderate
fund=false

# pnpm specific
shamefully-hoist=false
strict-peer-dependencies=true

# Performance
prefer-offline=true
cache-max=86400000

# Network timeout for local Verdaccio
timeout=10000