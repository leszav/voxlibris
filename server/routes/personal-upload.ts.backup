import express, { Request, Response } from "express";
import multer from "multer";
import { nanoid } from "nanoid";
import { db } from "../db";
import {
  uploadContexts,
  books,
  bookContent,
  userBooksLibrary,
  legalAcknowledgments,
  bookCollections,
  bookCollectionItems,
  type InsertUploadContext,
  type InsertLegalAcknowledgment,
  type InsertUserBookLibrary,
} from "@shared/schema";
import { eq, and, desc } from "drizzle-orm";
import { BookParserFactory, type ParsedBook } from "../book-parser";
import fileStorage from "../file-storage";
import { sanitizeBookContent } from "../content-sanitizer";

const router = express.Router();
const upload = multer({ storage: multer.memoryStorage() });

// Временное хранилище для upload sessions
const uploadSessions = new Map<
  string,
  {
    file: Buffer;
    filename: string;
    fileType: 'epub' | 'fb2';
    metadata: ParsedBook;
    userId: string;
    createdAt: Date;
  }
>();

// Очистка старых сессий (>30 минут)
setInterval(() => {
  const now = Date.now();
  const entries = Array.from(uploadSessions.entries());
  for (const [sessionId, session] of entries) {
    if (now - session.createdAt.getTime() > 30 * 60 * 1000) {
      uploadSessions.delete(sessionId);
    }
  }
}, 5 * 60 * 1000); // каждые 5 минут

/**
 * POST /api/v1/user/books/upload
 * Шаг 1: Загрузка файла и извлечение метаданных
 */
router.post("/upload", upload.single("file"), async (req: Request, res: Response) => {
  try {
    const userId = req.user?.id;
    if (!userId) {
      return res.status(401).json({ error: "Unauthorized" });
    }

    const file = req.file;
    if (!file) {
      return res.status(400).json({ error: "No file provided" });
    }

    // Определяем тип файла
    const fileType = BookParserFactory.detectFileType(file.originalname);
    if (!fileType) {
      return res.status(400).json({ error: "Unsupported file type. Only EPUB and FB2 are supported" });
    }

    // Парсинг метаданных
    const parser = BookParserFactory.createParser(fileType);
    const parsedData = await parser.parseBook(file.buffer, file.originalname);

    // Создание временной сессии
    const sessionId = nanoid();
    uploadSessions.set(sessionId, {
      file: file.buffer,
      filename: file.originalname,
      fileType: fileType,
      metadata: parsedData,
      userId,
      createdAt: new Date(),
    });

    // Возврат метаданных для подтверждения
    res.json({
      sessionId,
      metadata: {
        title: parsedData.metadata.title,
        author: parsedData.metadata.author,
        description: parsedData.metadata.description,
        isbn: parsedData.metadata.isbn,
        language: parsedData.metadata.language,
        publisher: parsedData.metadata.publisher,
        publishDate: parsedData.metadata.publishDate,
        coverPreview: parsedData.metadata.coverImageData 
          ? `data:image/${parsedData.metadata.coverImageType || 'jpeg'};base64,${parsedData.metadata.coverImageData.toString('base64')}`
          : null,
        totalChapters: parsedData.chapters?.length || 1,
        wordCount: parsedData.chapters?.reduce((sum, ch) => sum + ch.wordCount, 0) || 0,
        fileSize: file.size,
        contentType: parsedData.fileType,
      },
    });
  } catch (error) {
    console.error("[Personal Upload] Error in upload step:", error);
    res.status(500).json({ error: "Failed to process upload" });
  }
});

/**
 * POST /api/v1/user/books/upload/:sessionId/confirm
 * Шаг 2: Подтверждение и сохранение книги
 */
router.post("/upload/:sessionId/confirm", async (req: Request, res: Response) => {
  try {
    console.log('[Personal Upload] Confirm request received:', { sessionId: req.params.sessionId });
    
    const userId = req.user?.id;
    if (!userId) {
      console.error('[Personal Upload] No userId in request');
      return res.status(401).json({ error: "Unauthorized" });
    }

    const { sessionId } = req.params;
    const { metadata, legalAcknowledgment, collection } = req.body;

    console.log('[Personal Upload] Looking for session:', sessionId);
    
    // Получение сессии
    const session = uploadSessions.get(sessionId);
    if (!session || session.userId !== userId) {
      console.error('[Personal Upload] Session not found or userId mismatch', { 
        found: !!session, 
        expectedUserId: userId,
        actualUserId: session?.userId 
      });
      return res.status(404).json({ error: "Session not found or expired" });
    }

    console.log('[Personal Upload] Session found, creating upload context...');
    
    // Создание upload context
    const [uploadContext] = await db
      .insert(uploadContexts)
      .values({
        type: "personal",
        userId,
      } as InsertUploadContext)
      .returning();
    console.log('[Personal Upload] ✅ Upload context created:', uploadContext.id);

    // Сохранение legal acknowledgment
    if (legalAcknowledgment?.acknowledged) {
      await db.insert(legalAcknowledgments).values({
        userId,
        uploadContextId: uploadContext.id,
        ipAddress: req.ip || "unknown",
        userAgent: req.headers["user-agent"] || null,
      } as InsertLegalAcknowledgment);
      console.log('[Personal Upload] ✅ Legal acknowledgment saved');
    }

    // Загрузка файла в S3
    console.log('[Personal Upload] Uploading file to S3...', {
      filename: session.filename,
      fileType: session.fileType,
      fileSize: session.file.length
    });
    
    const uploadResult = await fileStorage.uploadFile(
      session.file,
      `${nanoid()}-${session.filename}`,
      session.fileType === "epub" 
        ? "application/epub+zip" 
        : "application/xml",
      `books/${userId}`
    );
    console.log('[Personal Upload] ✅ File uploaded to S3:', uploadResult.key);

    // Загрузка обложки если есть
    let coverUrl: string | null = null;
    const coverData = session.metadata.metadata?.coverImageData;
    const coverType = session.metadata.metadata?.coverImageType;
    
    if (coverData && Buffer.isBuffer(coverData)) {
      console.log('[Personal Upload] Uploading cover image...', {
        type: coverType,
        size: coverData.length
      });
      
      const coverResult = await fileStorage.uploadFile(
        coverData,
        `cover.${coverType || 'jpg'}`,
        `image/${coverType || 'jpeg'}`,
        `covers/${userId}/${nanoid()}`
      );
      coverUrl = coverResult.url;
      console.log('[Personal Upload] ✅ Cover uploaded:', coverResult.key);
    } else {
      console.log('[Personal Upload] No cover image in metadata');
    }

    // Создание записи книги с использованием переданных метаданных
    console.log('[Personal Upload] Creating book record...', {
      title: metadata?.title || session.metadata.metadata.title,
      author: metadata?.author || session.metadata.metadata.author,
      totalChapters: session.metadata.chapters?.length || 1
    });
    
    const bookData = {
      title: metadata?.title || session.metadata.metadata.title,
      author: metadata?.author || session.metadata.metadata.author,
      description: metadata?.description || session.metadata.metadata.description,
      isbn: metadata?.isbn || session.metadata.metadata.isbn,
      language: metadata?.language || session.metadata.metadata.language,
      publisher: metadata?.publisher || session.metadata.metadata.publisher,
      publishDate: metadata?.publishDate || session.metadata.metadata.publishDate,
      coverUrl,
      totalChapters: session.metadata.chapters?.length || 1,
      contentType: session.fileType,
      contentPath: uploadResult.key,
      originalFilename: session.filename,
      fileSize: session.file.length,
      uploadedBy: userId,
      uploadedAt: new Date(),
      wordCount: session.metadata.chapters?.reduce((sum, ch) => sum + ch.wordCount, 0) || 0,
      processingStatus: "completed" as const,
      uploadContextId: uploadContext.id,
      visibility: "private" as const,
    };

    const [book] = await db.insert(books).values(bookData).returning();
    console.log('[Personal Upload] ✅ Book record created:', book.id);

    // Сохранение контента по главам
    console.log('[Personal Upload] Saving book chapters...', {
      chaptersCount: session.metadata.chapters?.length || 0
    });
    
    if (session.metadata.chapters && session.metadata.chapters.length > 0) {
      for (const chapter of session.metadata.chapters) {
        const sanitizedContent = sanitizeBookContent(chapter.content);
        await db.insert(bookContent).values({
          bookId: book.id,
          chapterNumber: chapter.chapterNumber,
          title: chapter.title,
          content: sanitizedContent,
          wordCount: chapter.wordCount || 0,
        });
      }
      console.log('[Personal Upload] ✅ Saved', session.metadata.chapters.length, 'chapters');
    } else {
      // Если нет глав, создаем одну главу с полным содержимым
      const sanitizedContent = sanitizeBookContent("");
      await db.insert(bookContent).values({
        bookId: book.id,
        chapterNumber: 1,
        title: book.title,
        content: sanitizedContent,
        wordCount: book.wordCount,
      });
      console.log('[Personal Upload] ✅ Created single default chapter');
    }

    // Добавление в личную библиотеку пользователя
    await db.insert(userBooksLibrary).values({
      userId,
      bookId: book.id,
    } as InsertUserBookLibrary);
    console.log('[Personal Upload] ✅ Added to user library');

    // Создание коллекции если указана
    if (collection?.title) {
      console.log('[Personal Upload] Creating collection...', collection.title);
      
      const [newCollection] = await db
        .insert(bookCollections)
        .values({
          title: collection.title,
          description: collection.description || null,
          uploadContextId: uploadContext.id,
        })
        .returning();

      await db.insert(bookCollectionItems).values({
        collectionId: newCollection.id,
        bookId: book.id,
        position: collection.position || 1,
      });
      
      console.log('[Personal Upload] ✅ Collection created:', newCollection.id);
    }

    // Удаление сессии
    uploadSessions.delete(sessionId);
    console.log('[Personal Upload] ✅ Session cleaned up');
    console.log('[Personal Upload] 🎉 Upload completed successfully!');

    res.json({
      book: {
        id: book.id,
        title: book.title,
        author: book.author,
        coverUrl: book.coverUrl,
        totalChapters: book.totalChapters,
      },
      uploadContext: {
        id: uploadContext.id,
        type: uploadContext.type,
      },
    });
  } catch (error) {
    console.error("[Personal Upload] ❌ ERROR in confirm step:", error);
    console.error("[Personal Upload] Error name:", error instanceof Error ? error.name : 'Unknown');
    console.error("[Personal Upload] Error message:", error instanceof Error ? error.message : String(error));
    console.error("[Personal Upload] Error stack:", error instanceof Error ? error.stack : 'No stack trace');
    
    res.status(500).json({ 
      error: "Failed to save book",
      details: error instanceof Error ? error.message : String(error)
    });
  }
});

/**
 * GET /api/v1/user/books
 * Получение списка личных книг пользователя
 */
router.get("/", async (req: Request, res: Response) => {
  try {
    const userId = req.user?.id;
    if (!userId) {
      return res.status(401).json({ error: "Unauthorized" });
    }

    const userBooks = await db
      .select({
        id: books.id,
        title: books.title,
        author: books.author,
        coverUrl: books.coverUrl,
        description: books.description,
        language: books.language,
        totalChapters: books.totalChapters,
        contentType: books.contentType,
        addedAt: userBooksLibrary.addedAt,
        lastReadAt: userBooksLibrary.lastReadAt,
        createdAt: books.createdAt,
      })
      .from(userBooksLibrary)
      .innerJoin(books, eq(userBooksLibrary.bookId, books.id))
      .where(eq(userBooksLibrary.userId, userId))
      .orderBy(desc(userBooksLibrary.addedAt));

    res.json({ books: userBooks });
  } catch (error) {
    console.error("[Personal Upload] Error fetching user books:", error);
    res.status(500).json({ error: "Failed to fetch books" });
  }
});

/**
 * DELETE /api/v1/user/books/:bookId
 * Удаление книги из личной библиотеки
 */
router.delete("/:bookId", async (req: Request, res: Response) => {
  try {
    const userId = req.user?.id;
    if (!userId) {
      return res.status(401).json({ error: "Unauthorized" });
    }

    const { bookId } = req.params;

    // Проверка что книга принадлежит пользователю
    const [userBook] = await db
      .select()
      .from(userBooksLibrary)
      .where(
        and(
          eq(userBooksLibrary.userId, userId),
          eq(userBooksLibrary.bookId, bookId)
        )
      )
      .limit(1);

    if (!userBook) {
      return res.status(404).json({ error: "Book not found in your library" });
    }

    // Удаление из библиотеки (книга остается в системе)
    await db
      .delete(userBooksLibrary)
      .where(
        and(
          eq(userBooksLibrary.userId, userId),
          eq(userBooksLibrary.bookId, bookId)
        )
      );

    res.json({ message: "Book removed from library" });
  } catch (error) {
    console.error("[Personal Upload] Error deleting book:", error);
    res.status(500).json({ error: "Failed to delete book" });
  }
});

export default router;
