# ==============================================
# VoxLibris Environment Configuration Template
# ==============================================
# Copy this file to .env and fill in the values
# NEVER commit .env file with real credentials to git!

# Application Environment
# Options: development, production, staging
NODE_ENV=

# Database Configuration
# Format: postgresql://username:password@host:port/database
DATABASE_URL=

# Security Keys - Generate using:
# openssl rand -base64 32 (for JWT and SESSION secrets)
# openssl rand -hex 32 (for MASTER_KEY)
JWT_SECRET=
JWT_REFRESH_SECRET=
SESSION_SECRET=
MASTER_KEY=

# S3-Compatible Storage Configuration
# For AWS S3: https://s3.amazonaws.com
# For MinIO: http://your-minio-server:9000
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=

# MinIO Root Credentials (if using MinIO)
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# Optional: Client URL for email links
# CLIENT_URL=http://localhost:3000

# Optional: SMTP Configuration for emails
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=