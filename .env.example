# ==============================================
# VoxLibris Environment Configuration Template
# ==============================================
# Copy this file to .env and fill in the values
# NEVER commit .env file with real credentials to git!

# Application Environment
# Options: development, production, staging
NODE_ENV=

# Database Configuration
# Format: postgresql://username:password@host:port/database
DATABASE_URL=

# Security Keys - Generate using:
# openssl rand -base64 32 (for JWT and SESSION secrets)
# openssl rand -hex 32 (for MASTER_KEY)
JWT_SECRET=
JWT_REFRESH_SECRET=
SESSION_SECRET=
MASTER_KEY=

# S3-Compatible Storage Configuration
# For AWS S3: https://s3.amazonaws.com
# For MinIO: http://your-minio-server:9000
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=

# MinIO Root Credentials (if using MinIO)
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# Public URL used in emails and other external links (recommended)
# For each deployment environment set a single canonical URL:
# - local:   http://localhost:3000
# - staging: https://alfa.voxli.ru
# - prod:    https://voxli.ru
APP_BASE_URL=

# Optional: trusted public URL aliases (comma or semicolon separated).
# The first URL is used as canonical if APP_BASE_URL is empty.
# APP_BASE_URLS=https://voxli.ru;https://voxlibris.ru

# Legacy fallback (kept for backward compatibility)
# CLIENT_URL=http://localhost:3000

# Optional: SMTP Configuration for emails
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# Optional: Redis (distributed rate-limit store)
# Local (default in development): redis://:redis_dev@localhost:6379
# Production example: redis://:password@host:6379
# REDIS_PASSWORD=redis_dev
# REDIS_URL=redis://:password@redis-host:6379
# RATE_LIMIT_REDIS_URL=redis://:password@redis-host:6379
# RATE_LIMIT_REDIS_ENABLED=true
# RATE_LIMIT_REDIS_PREFIX=rl:voxlibris

# Optional: Risk-based rate-limit tuning
# RL_ANON_BURST_WINDOW_MS=5000
# RL_ANON_BURST_MAX=10
# RL_ANON_READ_WINDOW_MS=60000
# RL_ANON_READ_MAX=120
# RL_ANON_WRITE_WINDOW_MS=900000
# RL_ANON_WRITE_MAX=120
# RL_AUTH_READ_WINDOW_MS=900000
# RL_AUTH_READ_MAX=1200
# RL_AUTH_WRITE_WINDOW_MS=900000
# RL_AUTH_WRITE_MAX=300
# RL_EXPENSIVE_WINDOW_MS=900000
# RL_EXPENSIVE_MAX=30
# RL_AUTH_DELAY_WINDOW_MS=900000
# RL_AUTH_DELAY_AFTER=1000
# RL_GUEST_INIT_WINDOW_MS=900000
# RL_GUEST_INIT_MAX=10
# RL_GUEST_RESTORE_WINDOW_MS=300000
# RL_GUEST_RESTORE_MAX=5
# RL_GUEST_UPLOAD_WINDOW_MS=1800000
# RL_GUEST_UPLOAD_MAX=3
# RL_GUEST_ANALYTICS_WINDOW_MS=3600000
# RL_GUEST_ANALYTICS_MAX=100

# Optional: Request/upload safety limits
# JSON_BODY_LIMIT=15mb
# URLENCODED_BODY_LIMIT=1mb
# MAX_BOOK_UPLOAD_MB=50

# Guest Access Feature Flag
# Enable/disable guest account functionality (default: false)
# ENABLE_GUEST_ACCESS=false
# MAX_ACTIVE_UPLOAD_SESSIONS=200
# MAX_ACTIVE_UPLOAD_SESSIONS_PER_USER=5
# UPLOAD_SESSION_TTL_MINUTES=20

# ==============================================
# Icecast / Live Streaming Configuration
# ==============================================
# Internal Icecast server (within Docker network or same host)
# Default for CapRover: srv-captain--vl-icecast (Docker service name)
# ICECAST_INTERNAL_HOST=srv-captain--vl-icecast
# ICECAST_INTERNAL_PORT=8000

# Source authentication (set in both voxlibris-web and vl-icecast apps in CapRover)
# ICECAST_SOURCE_PASSWORD=<your-strong-source-password>

# Public URL for listeners (browsers will connect to this URL)
# Used by clients to construct /live/<sessionId> stream URLs
# Example: https://radio.voxlibris.ru
# ICECAST_PUBLIC_URL=https://radio.voxlibris.ru

# Vite env variable (for browser-side client builds)
# Must match ICECAST_PUBLIC_URL, used in client code to announce stream URLs
# VITE_ICECAST_PUBLIC_URL=https://radio.voxlibris.ru

# Optional: Custom recordings directory (ffmpeg MP3 output)
# Default: uploads/recordings (created at runtime)
# STUDIO_RECORDINGS_DIR=/path/to/recordings
# UPLOAD_SESSION_CLEANUP_INTERVAL_MINUTES=5

# ─── Icecast / VoxLibris Studio ───────────────────────────────────────────────
# source_password: используется бекендом для push потока на Icecast (НЕ клиентом)
ICECAST_SOURCE_PASSWORD=
ICECAST_ADMIN_PASSWORD=
# Внутренний адрес Icecast (Docker service name в dev / CapRover service name в prod)
ICECAST_INTERNAL_HOST=xlibris-icecast
ICECAST_INTERNAL_PORT=8000
# Публичный URL Icecast для слушателей (браузер)
ICECAST_PUBLIC_URL=http://localhost:8000
# Для клиентского кода (Vite)
VITE_ICECAST_PUBLIC_URL=http://localhost:8000
